generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("user")       // user | admin
  accessLevel   String    @default("pending")    // pending | sentiment | full
  onboarded     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  approvedAt    DateTime?
  approvedBy    String?
  adminNote     String?

  accounts      Account[]
  sessions      Session[]
  socialHandles SocialHandle[]
  brandProfile  BrandProfile?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SocialHandle {
  id        String   @id @default(cuid())
  userId    String
  platform  String   // linkedin | twitter | instagram
  handle    String?
  url       String?
  connected Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
}

model BrandProfile {
  id             String    @id @default(cuid())
  userId         String    @unique
  companyName    String?
  industry       String?
  description    String?
  stage          String?
  website        String?
  location       String?
  sentimentScore Float?
  healthScore    Float?
  mentionVolume  Int?
  researchData   Json?
  researchedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
